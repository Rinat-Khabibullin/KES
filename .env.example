# Vercel / local serverless function
LLM_CORS_ORIGIN=http://localhost:5173
LLM_CORS_ORIGINS=https://electrik-tuapse.ru,https://www.electrik-tuapse.ru

# Public Yandex Metrika counter ID for frontend and index.html.
VITE_YM_ID=110920709

# GigaChat credentials. Do not put real values in source control.
GIGACHAT_CREDENTIALS=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat-2
GIGACHAT_TIMEOUT=30

# Optional overrides. Defaults match current GigaChat REST endpoints.
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_URL=https://api.giga.chat/v1/chat/completions

# Local fallback when trusted certificates are not installed yet.
# Use true in Production. false is only a temporary diagnostic mode.
GIGACHAT_VERIFY_SSL=false
# GIGACHAT_CA_CERT_PATH=/absolute/path/to/russian_trusted_root_ca_pem.crt
# GIGACHAT_CA_CERT_BASE64=
